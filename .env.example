# MAXCES AI OS — Environment Configuration Template
# Copy this file to .env.local and populate with your credentials before building.

# Supabase Configurations
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Google Gemini API configurations (Optional but highly recommended for live AI operations)
# Get a key from Google AI Studio: https://aistudio.google.com/
VITE_GEMINI_API_KEY=your-gemini-api-key-here
